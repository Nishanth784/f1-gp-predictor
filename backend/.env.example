# ─── F1 Prediction System — Backend Environment Variables ───────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# ── Server ──────────────────────────────────────────────────────────────────

# Port the FastAPI server listens on (Render sets this automatically)
PORT=8011

# Set to "production" or "development"
ENVIRONMENT=development


# ── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# Leave blank in development (defaults to localhost:5173 and localhost:3000).
# In production, set this to your Netlify/custom domain — NO trailing slash.
#
# Example:
#   ALLOWED_ORIGINS=https://f1predictor.netlify.app,https://f1.yourdomain.com
#
ALLOWED_ORIGINS=


# ── FastF1 Cache ─────────────────────────────────────────────────────────────

# Directory for FastF1's local session cache.
# Render ephemeral disk: /tmp/fastf1_cache  (cleared on restart)
# Persistent disk:       /var/data/fastf1_cache
FASTF1_CACHE_DIR=./fastf1_cache


# ── Model Paths ──────────────────────────────────────────────────────────────

# Override default joblib model path if needed (usually auto-detected)
# WINNER_MODEL_PATH=./models/winner_model.joblib


# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Set to "true" to disable rate limiting in local dev
DISABLE_RATE_LIMITING=false


# ── Optional API Key ─────────────────────────────────────────────────────────
# If set, all POST/mutation endpoints require X-API-Key: <value> header.
# Leave blank to disable API key requirement.
# API_KEY=your_secret_key_here
